# AgentForge Environment Configuration
# Copy this file to .env and fill in your values

# NOT required: AgentForge uses your Claude Code session (OAuth) directly.
# Only set this if you want to use a raw API key instead of Claude Code auth.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: GitHub token for higher rate limits (60 req/hr without, 5000 with)
GITHUB_TOKEN=your_github_token_here

# Optional: Claude model to use (default: claude-opus-4-6)
AGENTFORGE_MODEL=claude-opus-4-6

# Optional: Output directory for generated projects
AGENTFORGE_OUTPUT_DIR=./agentforge_output
